@page "/receipts/list"
@using IBIZWebApp.Models
@inject IBIZWebApp.Services.IReceiptService ReceiptService
@inject IBIZWebApp.Services.IToastService ToastService
@inject NavigationManager Navigation

<div class="receipt-list-container">
    <!-- Header -->
    <div class="list-header">
        <h2>Receipts</h2>
        <div class="header-actions">
            <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/receipts")'>
                📝 Receipt Voucher
            </button>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/receipts/new")'>
                + New Receipt
            </button>
        </div>
    </div>

    <!-- Date Filters -->
    <div class="filter-card">
        <div class="filter-tabs">
            <button class="filter-tab @(ActiveFilter == "Daily" ? "active" : "")" @onclick="SetDaily">Daily</button>
            <button class="filter-tab @(ActiveFilter == "Monthly" ? "active" : "")" @onclick="SetMonthly">Monthly</button>
            <button class="filter-tab @(ActiveFilter == "Custom" ? "active" : "")" @onclick="SetCustom">Custom</button>
        </div>
        @if (ActiveFilter == "Custom")
        {
            <div class="custom-range">
                <div class="form-group">
                    <label>From</label>
                    <input type="date" class="form-control" @bind="FilterFrom" />
                </div>
                <div class="form-group">
                    <label>To</label>
                    <input type="date" class="form-control" @bind="FilterTo" />
                </div>
                <button class="btn btn-primary btn-sm" @onclick="SearchCustom">🔍 Search</button>
                <button class="btn btn-secondary btn-sm" @onclick="ResetCustom">↻ Reset</button>
            </div>
        }
    </div>

    <!-- Loading -->
    <LoadingSpinner IsVisible="@IsLoading" Message="Loading receipts..." />

    @if (!IsLoading)
    {
        @if (Receipts.Any())
        {
            <!-- Receipt Table -->
            <div class="table-card">
                <div class="table-responsive">
                    <table class="receipt-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer Name</th>
                                <th>Receipt No.</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Payment Mode</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Receipts)
                            {
                                <tr>
                                    <td>@r.OrderId</td>
                                    <td>@r.CustomerName</td>
                                    <td><strong>@r.ReceiptNo</strong></td>
                                    <td>@r.ReceiptDate.ToString("yyyy-MM-dd")</td>
                                    <td class="amt">₹@r.Amount.ToString("N2")</td>
                                    <td>
                                        <span class="badge @GetStatusBadge(r.Status)">@r.Status</span>
                                    </td>
                                    <td>@r.PaymentMode</td>
                                    <td class="actions-cell">
                                        <button class="btn-icon btn-view" title="View" @onclick="() => ViewReceipt(r.ReceiptId)">👁</button>
                                        <button class="btn-icon btn-edit" title="Edit" @onclick="() => EditReceipt(r.ReceiptId)">✏️</button>
                                        <button class="btn-icon btn-delete" title="Delete" @onclick="() => ConfirmDelete(r)">🗑</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            <Pagination PageNumber="@PageNumber" PageSize="@PageSize" TotalCount="@TotalCount"
                        OnPageChanged="OnPageChanged" OnPageSizeChanged="OnPageSizeChanged" />
        }
        else
        {
            <div class="empty-state">
                <span class="empty-icon">📭</span>
                <p>No receipts found for the selected date range.</p>
            </div>
        }
    }
</div>

<!-- Confirm Delete Dialog -->
<ConfirmDialog IsVisible="@ShowDeleteConfirm"
               Title="Delete Receipt"
               Message="@($"Are you sure you want to delete receipt {ReceiptToDelete?.ReceiptNo}?")"
               ConfirmButtonText="Delete"
               OnConfirm="@(() => DeleteConfirmed())"
               OnCancel="@(() => { ShowDeleteConfirm = false; ReceiptToDelete = null; })" />

@code {
    private List<Receipt> Receipts = new();
    private bool IsLoading;
    private string ActiveFilter = "Daily";
    private DateTime FilterFrom = DateTime.Today;
    private DateTime FilterTo = DateTime.Today;
    private int PageNumber = 1;
    private int PageSize = 10;
    private int TotalCount;

    private bool ShowDeleteConfirm;
    private Receipt? ReceiptToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadReceipts();
    }

    private async Task LoadReceipts()
    {
        IsLoading = true;
        try
        {
            ApiResponse<PaginatedResult<Receipt>> apiResult;
            // If filter is Daily, Monthly, or Custom, pass date filter
            if (ActiveFilter == "Daily" || ActiveFilter == "Monthly" || (ActiveFilter == "Custom" && FilterFrom != default && FilterTo != default))
            {
                apiResult = await ReceiptService.SearchReceiptsByDateAsync(FilterFrom, FilterTo, PageNumber, PageSize);
            }
            else
            {
                apiResult = await ReceiptService.GetReceiptsAsync(new PaginationParams { PageNumber = PageNumber, PageSize = PageSize });
            }
            if (apiResult.Status == "success" && apiResult.Data != null)
            {
                Receipts = apiResult.Data.Items;
                TotalCount = apiResult.Data.TotalCount;
            }
            else
            {
                Receipts = new List<Receipt>();
                TotalCount = 0;
                await ToastService.ShowErrorAsync($"Failed to load receipts: {apiResult.Message}");
            }
        }
        catch (Exception ex)
        {
            await ToastService.ShowErrorAsync($"Failed to load receipts: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SetDaily()
    {
        ActiveFilter = "Daily";
        FilterFrom = DateTime.Today;
        FilterTo = DateTime.Today;
        PageNumber = 1;
        await LoadReceipts();
    }

    private async Task SetMonthly()
    {
        ActiveFilter = "Monthly";
        FilterFrom = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        FilterTo = FilterFrom.AddMonths(1).AddDays(-1);
        PageNumber = 1;
        await LoadReceipts();
    }

    private void SetCustom()
    {
        ActiveFilter = "Custom";
    }

    private async Task SearchCustom()
    {
        PageNumber = 1;
        await LoadReceipts();
    }

    private async Task ResetCustom()
    {
        FilterFrom = DateTime.Today.AddDays(-30);
        FilterTo = DateTime.Today;
        PageNumber = 1;
        await LoadReceipts();
    }

    private async Task OnPageChanged(int page)
    {
        PageNumber = page;
        await LoadReceipts();
    }

    private async Task OnPageSizeChanged(int size)
    {
        PageSize = size;
        PageNumber = 1;
        await LoadReceipts();
    }

    private void ViewReceipt(int id) => Navigation.NavigateTo($"/receipts/{id}");
    private void EditReceipt(int id) => Navigation.NavigateTo($"/receipts/{id}");

    private void ConfirmDelete(Receipt receipt)
    {
        ReceiptToDelete = receipt;
        ShowDeleteConfirm = true;
        StateHasChanged();
    }

    private async Task DeleteConfirmed()
    {
        Console.WriteLine("DeleteConfirmed called");
        if (ReceiptToDelete == null) return;
        ShowDeleteConfirm = false;
        try
        {
            var ok = await ReceiptService.DeleteReceiptAsync(ReceiptToDelete.ReceiptId);
            if (ok)
                await ToastService.ShowSuccessAsync("Receipt deleted successfully.");
            else
                await ToastService.ShowErrorAsync("Failed to delete receipt.");

            await LoadReceipts();
        }
        catch (Exception ex)
        {
            await ToastService.ShowErrorAsync($"Delete failed: {ex.Message}");
        }
        finally
        {
            ReceiptToDelete = null;
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Pending" => "badge-warning",
        "Received" => "badge-success",
        "Reconciled" => "badge-info",
        "Cancelled" => "badge-danger",
        _ => "badge-secondary"
    };
}
