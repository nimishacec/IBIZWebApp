            string order_id = Order.OrderId ?? string.Empty;
            Order.OrderId = OrderId;
            var isEdit = IsEdit && !string.IsNullOrEmpty(Order.OrderId) && Order.OrderId != "0";

            // Fetch last InvId from API if not edit
            if (!isEdit)
            {
                await FetchNewInvIdAsync("SALES", "Sales");
            }

