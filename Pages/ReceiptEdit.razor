@page "/receipts/{id}/edit"
@inject IBIZWebApp.Services.IReceiptService ReceiptService
@inject NavigationManager Navigation

<h3>Edit Receipt</h3>

@if (IsLoading)
{
    <p>Loading...</p>
}
else if (Receipt == null)
{
    <p>Receipt not found.</p>
}
else
{
    <EditForm Model="Receipt" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div>
            <label>Receipt No:</label>
            <InputText @bind-Value="Receipt.ReceiptNo" class="form-control" />
        </div>
        <div>
            <label>Customer Name:</label>
            <InputText @bind-Value="Receipt.CustomerName" class="form-control" />
        </div>
        <div>
            <label>Amount:</label>
            <InputNumber @bind-Value="Receipt.Amount" class="form-control" />
        </div>
        <div>
            <label>Status:</label>
            <InputText @bind-Value="Receipt.Status" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary" @onclick="GoBack">Cancel</button>
    </EditForm>
}

@code {
    [Parameter] public string id { get; set; }
    private IBIZWebApp.Models.Receipt? Receipt;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var response = await ReceiptService.GetReceiptByIdAsync(int.TryParse(id, out var rid) ? rid : 0);
        Receipt = response.Data;
        IsLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (Receipt != null)
        {
            await ReceiptService.UpdateReceiptAsync(Receipt);
            Navigation.NavigateTo("/receipts/list");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/receipts/list");
    }
}
