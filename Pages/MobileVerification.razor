@page "/"
@page "/mobile-verification"
@using IBIZWebApp.Services
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IBIZWebApp.Services.UserSessionService UserSession



<PageTitle>Mobile Verification</PageTitle>

<div class="login-container mobile-optimized center-align">
    <h1>Mobile Verification</h1>
    <form @onsubmit="HandleGetOTP">
        <div class="form-group">
            <label for="mobileNumber">Enter your mobile number :</label>
            <input 
                type="tel" 
                id="mobileNumber" 
                @bind="MobileNumber"
                placeholder="Enter mobile number"
                required
                class="form-control" 
                disabled="@IsLoading" />
        </div>
        <button type="submit" class="btn btn-primary" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span>Loading...</span>
            }
            else
            {
                <span>Get OTP</span>
            }
        </button>
    </form>
    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert @(IsSuccess ? "alert-success" : "alert-danger") mt-3">
            @Message
        </div>
    }
</div>

<style>

    @@media (max-width: 600px) {
        .login-container {
            width: 100vw;
            max-width: 100vw;
            margin: 0 auto;
            padding: 32px 0 24px 0;
            background: #fff;
            border-radius: 0;
            box-shadow: none;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
        .login-container.center-align {
            align-items: center;
            justify-content: center;
            padding-left: 0;
        }
        .login-container form {
            width: 90vw;
            max-width: 400px;
        }
    }

    .login-container h1 {
        text-align: center;
        margin-bottom: 24px;
        font-size: 1.7rem;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
    }

    .form-group input {
        width: 100%;
        padding: 14px 12px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 1.1rem;
        box-sizing: border-box;
        background: #f9f9f9;
    }

    .form-group input:focus {
        outline: none;
        border-color: #007bff;
        box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
    }

    .form-group input:disabled {
        background-color: #e9ecef;
        cursor: not-allowed;
    }

    .btn {
        width: 100%;
        padding: 14px 0;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1.1rem;
        font-weight: bold;
        transition: background-color 0.3s ease;
        margin-top: 10px;
        touch-action: manipulation;
    }
    /* Responsive tweaks for small screens */
    @@media (max-width: 480px) {
        .login-container {
            padding: 18vw 2vw 10vw 2vw;
            border-radius: 0;
            min-height: 100vh;
            box-shadow: none;
        }
        .form-group input {
            font-size: 1rem;
            padding: 12px 8px;
        }
        .btn {
            font-size: 1rem;
            padding: 12px 0;
        }
    }

    .btn-primary {
        background-color: #007bff;
    }

    .btn-primary:hover:not(:disabled) {
        background-color: #0056b3;
    }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .alert {
        padding: 12px;
        border-radius: 4px;
        border: 1px solid #d1ecf1;
    }

    .alert-success {
        border-color: #c3e6cb;
        background-color: #d4edda;
        color: #155724;
    }

    .alert-danger {
        border-color: #f5c6cb;
        background-color: #f8d7da;
        color: #721c24;
    }
</style>

@code {
    private string? MobileNumber { get; set; }
    private string? Message { get; set; }
    private bool IsSuccess { get; set; }
    private bool IsLoading { get; set; }

    private async Task HandleGetOTP()
    {
        if (string.IsNullOrWhiteSpace(MobileNumber))
        {
            Message = "Please enter a mobile number";
            IsSuccess = false;
            return;
        }

        IsLoading = true;
        Message = null;

        var result = await AuthService.GetOTPAsync(MobileNumber);

        if (result.IsSuccess)
        {
            // Store the entered mobile number in UserSession for later use (logout, etc.)
            await UserSession.SetMobileNoAsync(MobileNumber);
            // Navigate to OTP verification page, passing the mobile number
            Navigation.NavigateTo($"/otp-verification?mobile={Uri.EscapeDataString(MobileNumber)}");
        }
        else
        {
            Message = result.Message;
            IsSuccess = false;
        }

        IsLoading = false;
    }
}
