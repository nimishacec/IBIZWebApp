@page "/receipts/{id}"
@using IBIZWebApp.Models
@inject IBIZWebApp.Services.IReceiptService ReceiptService
@inject NavigationManager Navigation

<h3>View Receipt</h3>

@if (IsLoading)
{
    <p>Loading...</p>
}
else if (Receipt == null)
{
    <p>Receipt not found.</p>
}
else
{
    <div class="receipt-details">
        <div><strong>Receipt No:</strong> @Receipt.ReceiptNo</div>
        <div><strong>Customer Name:</strong> @Receipt.CustomerName</div>
        <div><strong>Amount:</strong> @Receipt.Amount</div>
        <div><strong>Status:</strong> @Receipt.Status</div>
        <div><strong>Date:</strong> @Receipt.ReceiptDate.ToString("yyyy-MM-dd")</div>
        <button class="btn btn-secondary" @onclick="GoBack">Back</button>
    </div>
}

@code {
    [Parameter] public string? id { get; set; }
    private IBIZWebApp.Models.Receipt? Receipt;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var response = await ReceiptService.GetReceiptByIdAsync(int.TryParse(id, out var rid) ? rid : 0);
        Receipt = response.Data;
        IsLoading = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/receipts/list");
    }
}
