    {
        if (!string.IsNullOrEmpty(_pendingMonth))
            SelectedMonth = _pendingMonth;
        if (_pendingYear != 0)
            SelectedYear = _pendingYear;
        CurrentPage = 1;
        StateHasChanged();
    }
