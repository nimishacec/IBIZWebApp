@page "/sales-summary"
@using IBIZWebApp.Models
@using IBIZWebApp.Services
@inject HttpClient Http
@inject ICompanySelectionService CompanyService
@inject UserSessionService UserSession

@inject IJSRuntime? JS
<!-- Responsive mobile tweaks -->
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
</head>
<style>
    @@media (max-width: 600px) {
        .daybook-page, .daybook-hero, .daybook-table-card, .card, .table, .daybook-pagination {
            padding-left: 2vw !important;
            padding-right: 2vw !important;
        }
        .daybook-label, .daybook-date, .btn, .btn-pill, .form-label, .form-select, .nav-link {
            font-size: 1rem !important;
        }
        .dropdown-menu, .dropdown-item {
            font-size: 1rem !important;
        }
        .daybook-hero h1, .daybook-hero p, .daybook-hero span {
            font-size: 1.1rem !important;
        }
        .daybook-table-card {
            margin-left: 0 !important;
            margin-right: 0 !important;
        }
        .table {
            font-size: 13px !important;
        }
    }
</style>

<div class="daybook-page">
    <div class="daybook-hero card shadow-sm">
        <div>
            <p class="daybook-label">Sales Summary</p>
            <div class="daybook-date">
                <span>@_snapshotTimestamp.ToString("dd, MMM yyyy")</span>
                <span>@_snapshotTimestamp.ToString("hh:mm tt")</span>
            </div>
        </div>
        <div class="daybook-actions">
            <div class="btn-group">
                <div style="position:relative;display:inline-block;">
                    <button class="btn btn-outline-light btn-pill dropdown-toggle" type="button" @onclick="ToggleColumnsDropdown" aria-expanded="@(ShowColumnsDropdown ? "true" : "false")">
                        Columns
                    </button>
                    @if (ShowColumnsDropdown)
                    {
                        <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:1040;background:rgba(0,0,0,0.01);" @onclick="CloseColumnsDropdown"></div>
                        <div class="dropdown-menu dropdown-menu-end daybook-columns show" style="position:absolute;z-index:1050;min-width:220px;max-height:350px;overflow-y:auto;box-shadow:0 4px 24px rgba(0,0,0,0.18);background:#fff;border-radius:8px;">
                            @foreach (var column in GridColumns)
                            {
                                var isVisible = VisibleColumns.TryGetValue(column.PropertyName, out var visible) ? visible : true;
                                <label class="dropdown-item form-check mb-0">
                                    <input class="form-check-input me-2" type="checkbox" checked="@isVisible" @onchange="() => ToggleColumn(column.PropertyName)" />
                                    <span>@column.Header</span>
                                </label>
                            }
                        </div>
                    }
                </div>
                              </div>
            <button class="btn btn-outline-light btn-pill" @onclick="ToggleFilter">Filter</button>
            <div class="btn-group">
                <div style="position:relative;display:inline-block;">
                    <button class="btn btn-outline-light btn-pill dropdown-toggle" type="button" @onclick="ToggleExportDropdown" aria-expanded="@(ShowExportDropdown ? "true" : "false")">
                        Export
                    </button>
                    @if (ShowExportDropdown)
                    {
                        <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:1040;background:rgba(0,0,0,0.01);" @onclick="CloseExportDropdown"></div>
                        <ul class="dropdown-menu dropdown-menu-end show" style="position:absolute;z-index:1050;min-width:180px;">
                            <li><a class="dropdown-item" @onclick="ExportToPdf">Export to PDF</a></li>
                            <li><a class="dropdown-item" @onclick="ExportToCsv">Export to CSV</a></li>
                            <li><a class="dropdown-item" @onclick="ExportToExcel">Export to Excel</a></li>
                        </ul>
                    }
                </div>
                
            </div>
            <button class="btn btn-outline-light btn-pill" @onclick="RefreshData">Refresh</button>
        </div>
    </div>

    <div class="daybook-tabs nav nav-pills flex-wrap gap-2 mt-3">
        <button class="nav-link @(ActiveTab == "Summary" ? "active" : null)" @onclick='async () => await SetTab("Summary")'>Summary</button>
        <button class="nav-link @(ActiveTab == "Today" ? "active" : null)" @onclick='async () => await SetTab("Today")'>Today</button>
        <button class="nav-link @(ActiveTab == "Month" ? "active" : null)" @onclick='async () => await SetTab("Month")'>Month</button>
        <button class="nav-link @(ActiveTab == "Year" ? "active" : null)" @onclick='async () => await SetTab("Year")'>Year</button>
        <button class="nav-link @(ActiveTab == "Custom" ? "active" : null)" @onclick='async () => await SetTab("Custom")'>Custom</button>
    </div>

    @if (ActiveTab == "Month")
    {
        <div class="card daybook-table-card mt-3 mb-3 p-3">
            <div class="row g-3 align-items-end m-0">
                <div class="col-md-3">
                    <label class="form-label">Month</label>
                    <select class="form-select" @bind="_pendingMonth">
                        @foreach (var month in AvailableMonths)
                        {
                            <option value="@month">@month</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Year</label>
                    <select class="form-select" @bind="_pendingYear">
                        @foreach (var year in AvailableYears)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="ApplyMonthYearFilter">Apply</button>
                </div>
            </div>
        </div>
    }
    @if (ActiveTab == "Year")
    {
        <div class="card daybook-table-card mt-3 mb-3 p-3">
            <div class="row g-3 align-items-end m-0">
                <div class="col-md-3">
                    <label class="form-label">Year</label>
                    <select class="form-select" @bind="SelectedYear">
                        @foreach (var year in AvailableYears)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="ApplyMonthYearFilter">Apply</button>
                </div>
            </div>
        </div>
    }
    @if (ActiveTab == "Custom")
    {
        <div class="card daybook-table-card mt-3 mb-3 p-3">
            <div class="row g-3 align-items-end m-0">
                <div class="col-md-3">
                    <label class="form-label">Date From</label>
                    <input type="date" class="form-control" @bind="StartDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Date To</label>
                    <input type="date" class="form-control" @bind="EndDate" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="ApplyCustomFilter">Apply</button>
                </div>
            </div>
        </div>
    }

    @if (ShowFilter)
    {
        <div class="daybook-filter card mt-3">
            <div class="filter-header d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Filters</h5>
                <button type="button" class="btn btn-sm btn-link" @onclick="ToggleFilter">Hide</button>
            </div>
            <div class="filter-grid">
                <div class="filter-card">
                    <h6>Cost Centre</h6>
                    @if (!CostCenters.Any())
                    {
                        <p class="text-muted small mb-0">No cost centres available.</p>
                    }
                    else
                    {
                        @foreach (var option in CostCenters)
                        {
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@option.Selected" @onchange="e => OnFilterOptionChanged(e, option)" />
                                <span class="form-check-label">@option.Name</span>
                            </label>
                        }
                    }
                </div>
                <div class="filter-card">
                    <h6>Mode of Payment</h6>
                    @if (!ModeOfPayments.Any())
                    {
                        <p class="text-muted small mb-0">No payment modes available.</p>
                    }
                    else
                    {
                        @foreach (var option in ModeOfPayments)
                        {
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@option.Selected" @onchange="e => OnFilterOptionChanged(e, option)" />
                                <span class="form-check-label">@option.Name</span>
                            </label>
                        }
                    }
                </div>
                <div class="filter-card">
                    <h6>Tax Mode</h6>
                    @if (!TaxModes.Any())
                    {
                        <p class="text-muted small mb-0">No tax modes available.</p>
                    }
                    else
                    {
                        @foreach (var option in TaxModes)
                        {
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@option.Selected" @onchange="e => OnFilterOptionChanged(e, option)" />
                                <span class="form-check-label">@option.Name</span>
                            </label>
                        }
                    }
                </div>
                <div class="filter-card">
                    <h6>Sales Person</h6>
                    @if (!SalesMan.Any())
                    {
                        <p class="text-muted small mb-0">No sales users available.</p>
                    }
                    else
                    {
                        @foreach (var option in SalesMan)
                        {
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@option.Selected" @onchange="e => OnFilterOptionChanged(e, option)" />
                                <span class="form-check-label">@option.Name</span>
                            </label>
                        }
                    }
                </div>
                <div class="filter-card">
                    <h6>Voucher Type</h6>
                    @if (!VoucherTypes.Any())
                    {
                        <p class="text-muted small mb-0">No voucher types available.</p>
                    }
                    else
                    {
                        @foreach (var option in VoucherTypes)
                        {
                            <label class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@option.Selected" @onchange="e => OnFilterOptionChanged(e, option)" />
                                <span class="form-check-label">@option.Name</span>
                            </label>
                        }
                    }
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger mt-3">@ErrorMessage</div>
    }
    else if (IsLoading)
    {
        <div class="daybook-loading card mt-3">Loading sales data...</div>
    }
    else{
        var tabData = GetTabData();
        var isSummaryTab = ActiveTab == "Summary";
        var totalPages = isSummaryTab ? 1 : Math.Max(1, (int)Math.Ceiling((double)Math.Max(1, tabData.Count) / RowsPerPage));
        if (isSummaryTab)
        {
            // ...existing code for summary tab...
            var months = new[] { "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December" };
            var costCentres = tabData.Select(r => (r.CCName ?? "").Replace("<", string.Empty).Replace(">", string.Empty)).Distinct().OrderBy(x => x).ToList();
            var billMatrix = new Dictionary<string, Dictionary<string, decimal>>();
            foreach (var cc in costCentres)
            {
                billMatrix[cc] = new Dictionary<string, decimal>();
                foreach (var m in months)
                {
                    billMatrix[cc][m] = tabData.Where(r => ((r.CCName ?? "").Replace("<", string.Empty).Replace(">", string.Empty)) == cc && (r.Month ?? "") == m).Sum(r => r.BillAmt ?? 0);
                }
            }
            var monthTotals = new Dictionary<string, decimal>();
            foreach (var m in months)
            {
                monthTotals[m] = tabData.Where(r => (r.Month ?? "") == m).Sum(r => r.BillAmt ?? 0);
            }
        <div class="card daybook-table-card mt-3">
            <div class="table-responsive">
                <table class="table daybook-table">
                    <thead>
                        <tr class="custom-header">
                            <th>Cost Centre</th>
                            @foreach (var m in months)
                            {
                                <th>@m</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cc in costCentres)
                        {
                            <tr>
                                <td>@(cc.Replace("&lt;", "").Replace("&gt;", "").Replace("<", string.Empty).Replace(">", string.Empty))</td>
                                @foreach (var m in months)
                                {
                                    <td class="text-end">@billMatrix[cc][m].ToString("N2")</td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="grand-total-row">
                            <td class="grand-label">Grand Total</td>
                            @foreach (var m in months)
                            {
                                <td class="text-end">@monthTotals[m].ToString("N2")</td>
                            }
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        }
        else
        {
            var visibleColumns = GetVisibleColumns().ToList();
            var pageRows = tabData.Skip((CurrentPage - 1) * RowsPerPage).Take(RowsPerPage).ToList();
            var billTotal = tabData.Sum(r => r.BillAmt ?? 0);
            @if (!visibleColumns.Any())
            {
                <div class="daybook-empty card mt-3">Select at least one column to display the report.</div>
            }
            else if (!pageRows.Any())
            {
                <div class="daybook-empty card mt-3">No records found for the selected filters.</div>
            }
            else
            {
                <div class="card daybook-table-card mt-3">
                    <div class="table-responsive">
                        <table class="table daybook-table">
                            <thead>
                                <tr class="custom-header">
                                    @foreach (var column in visibleColumns)
                                    {
                                        <th>@column.Header</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in pageRows)
                                {
                                    <tr>
                                        @foreach (var column in visibleColumns)
                                        {
                                            var value = GetFormattedValue(row, column.PropertyName);
                                            if (column.PropertyName == nameof(SalesReportItem.CCName) && value is string ccVal)
                                            {
                                                value = ccVal.Replace("<", string.Empty).Replace(">", string.Empty);
                                            }
                                            if (column.PropertyName == nameof(SalesReportItem.Party) && value is string partyVal)
                                            {
                                                value = partyVal.Replace("<", string.Empty).Replace(">", string.Empty);
                                            }
                                            <td class="@(column.IsNumeric ? "text-end" : "text-start")">@value</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="grand-total-row">
                                    @{
                                        var labelPlaced = false;
                                    }
                                    @foreach (var column in visibleColumns)
                                    {
                                        if (column.PropertyName == nameof(SalesReportItem.GrossAmt))
                                        {
                                            <td class="text-end">@tabData.Sum(r => r.GrossAmt ?? 0).ToString("N2")</td>
                                        }
                                        else if (column.PropertyName == nameof(SalesReportItem.Taxable))
                                        {
                                            <td class="text-end">@tabData.Sum(r => r.Taxable ?? 0).ToString("N2")</td>
                                        }
                                        else if (column.PropertyName == nameof(SalesReportItem.TaxAmt))
                                        {
                                            <td class="text-end">@tabData.Sum(r => r.TaxAmt ?? 0).ToString("N2")</td>
                                        }
                                        else if (column.PropertyName == nameof(SalesReportItem.BillAmt))
                                        {
                                            <td class="text-end">@billTotal.ToString("N2")</td>
                                        }
                                        else
                                        {
                                            if (!labelPlaced)
                                            {
                                                <td class="grand-label">Grand Total</td>
                                                labelPlaced = true;
                                            }
                                            else
                                            {
                                                <td></td>
                                            }
                                        }
                                    }
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }
        }

        @if (!isSummaryTab)
        {
            <div class="daybook-pagination modern-pagination d-flex align-items-center gap-3 mt-3 justify-content-start" style="background:#f8f9fa;padding:10px 18px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                <span class="fw-bold">Page</span>
                <button class="btn btn-primary btn-sm px-3" @onclick="PrevPage" disabled="@(CurrentPage == 1)">&#8592;</button>
                <span class="fs-6">@CurrentPage <span class="text-muted">/ @totalPages</span></span>
                <button class="btn btn-primary btn-sm px-3" @onclick="NextPage" disabled="@(CurrentPage >= totalPages)">&#8594;</button>
                <span class="ms-3">Rows:</span>
                <select class="form-select form-select-sm rows-per-page-select w-auto d-inline-block" value="@RowsPerPage" @onchange="OnRowsPerPageChanged">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
        }
    }
</div>

@code {
    private readonly DateTime _snapshotTimestamp = DateTime.Now;

    private record ColumnDefinition(string Header, string PropertyName, bool IsNumeric = false);
private bool ShowColumnsDropdown = false;
    private void ToggleColumnsDropdown()
    {
        ShowColumnsDropdown = !ShowColumnsDropdown;
    }
    private void CloseColumnsDropdown()
    {
        ShowColumnsDropdown = false;
        StateHasChanged();
    }
    private bool ShowExportDropdown = false;
                private void ToggleExportDropdown()
                {
                    ShowExportDropdown = !ShowExportDropdown;
                }
                private void CloseExportDropdown()
                {
                    ShowExportDropdown = false;
                    StateHasChanged();
                }
    private readonly List<ColumnDefinition> GridColumns = new()
    {
        new("Invoice No", nameof(SalesReportItem.InvNo)),
        new("Invoice Date", nameof(SalesReportItem.Date)),
        new("Invoice Time", nameof(SalesReportItem.Time)),
        new("CostCentre", nameof(SalesReportItem.CCName)),
        new("Reference No", nameof(SalesReportItem.InvId)),
        new("VoucherType", nameof(SalesReportItem.VchType)),
        new("PartyCode", nameof(SalesReportItem.Party)),
        new("Party", nameof(SalesReportItem.Party)),
        new("PartyAddress", nameof(SalesReportItem.PartyAddress)),
        new("Mobile No", nameof(SalesReportItem.MobileNo)),
        new("MOP", nameof(SalesReportItem.Mop)),
        new("Tax No", nameof(SalesReportItem.TaxMode)),
        new("UserNarration", nameof(SalesReportItem.UserNarration)),
        new("Delivery Details", nameof(SalesReportItem.DeliveryDetails)),
        new("Dispatch Details", nameof(SalesReportItem.DespatchDetails)),
        new("Terms of Delivery", nameof(SalesReportItem.TermsOfDelivery)),
        new("Order Details", nameof(SalesReportItem.OrderDetails)),
        new("Gross Amount", nameof(SalesReportItem.GrossAmt), true),
        new("Taxable", nameof(SalesReportItem.Taxable), true),
        new("Tax Amount", nameof(SalesReportItem.TaxAmt), true),
        new("Bill Amount", nameof(SalesReportItem.BillAmt), true)
    };

    private Dictionary<string, bool> VisibleColumns = new();
    // Ensure all columns are initialized as visible
    private void EnsureVisibleColumnsInitialized()
    {
        foreach (var col in GridColumns)
        {
            if (!VisibleColumns.ContainsKey(col.PropertyName))
            {
                VisibleColumns[col.PropertyName] = true;
            }
        }
    }
    private bool ShowFilter;
    private bool IsLoading;
    private string ActiveTab = "Summary";
    private string? SelectedMonth = DateTime.Now.ToString("MMMM");
    private int SelectedYear = DateTime.Now.Year;
    private List<string> AvailableMonths { get; set; } = new()
    {
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    };
    private List<int> AvailableYears { get; set; } = new() { DateTime.Now.Year };
    private DateTime? StartDate;
    private DateTime? EndDate;
    private int RowsPerPage { get; set; } = 10;
    private int CurrentPage { get; set; } = 1;
    private string? ErrorMessage;

    private List<FilterOption> CostCenters = new();
    private List<FilterOption> ModeOfPayments = new();
    private List<FilterOption> TaxModes = new();
    private List<FilterOption> SalesMan = new();
    private List<FilterOption> VoucherTypes = new();

    private List<SalesReportItem> FilteredSalesData = new();
    private List<SalesReportItem> AllSalesData = new();
    private const string AppID = "GFW79L496PM4557UD3KEERR0W";

        // Ensure data loads on first page load
        protected override async Task OnInitializedAsync()
        {
            EnsureVisibleColumnsInitialized();
            // Load selected company from storage if not already set
            await CompanyService.LoadSelectedCompanyAsync();
            await LoadSalesDataAsync();
        }
    

    private async Task LoadSalesDataAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;
            List<SalesReportItem>? items = null;
            var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            if (ActiveTab == "Summary")
            {
                var company = CompanyService.SelectedCompany;
                if (company == null)
                {
                    ErrorMessage = "No company selected. Please select a company to view sales summary.";
                    IsLoading = false;
                    AllSalesData = new List<SalesReportItem>();
                    FilteredSalesData = new List<SalesReportItem>();
                    await InvokeAsync(StateHasChanged);
                    return;
                }
                var url = $"{IBIZWebApp.ApiConstants.BaseUrl}/App/GetJson";
                var requestBody = new { vchrType = "SALES" };
                var postRequest = new HttpRequestMessage(HttpMethod.Post, url)
                {
                    Content = new StringContent(System.Text.Json.JsonSerializer.Serialize(requestBody), System.Text.Encoding.UTF8, "application/json")
                };
                if (!string.IsNullOrEmpty(company.LicenceKey))
                {
                    postRequest.Headers.Add("CdKey", company.LicenceKey);
                }
                if (!string.IsNullOrEmpty(company.CompanyCode))
                {
                    postRequest.Headers.Add("CompanyCode", company.CompanyCode);
                }

                var response = await Http.SendAsync(postRequest);
                if (!response.IsSuccessStatusCode)
                {
                    throw new Exception($"Failed to load data: {response.StatusCode}");
                }

                var jsonData = await response.Content.ReadAsStringAsync();
                if (!string.IsNullOrWhiteSpace(jsonData))
                {
                    var trimmed = jsonData.Trim();
                    // Handle double-encoded JSON: ["[ {...}, {...} ]"]
                    if (trimmed.StartsWith("[") && trimmed.EndsWith("]"))
                    {
                        try
                        {
                            // Try direct deserialization
                            items = System.Text.Json.JsonSerializer.Deserialize<List<SalesReportItem>>(trimmed, options);
                        }
                        catch
                        {
                            // Try double-deserialization: first to List<string>, then to List<SalesReportItem>
                            try
                            {
                                var stringArray = System.Text.Json.JsonSerializer.Deserialize<List<string>>(trimmed, options);
                                if (stringArray != null && stringArray.Count > 0)
                                {
                                    var inner = stringArray[0];
                                    items = System.Text.Json.JsonSerializer.Deserialize<List<SalesReportItem>>(inner, options);
                                }
                            }
                            catch (Exception ex2)
                            {
                                ErrorMessage = $"Failed to parse double-encoded JSON: {ex2.Message}";
                            }
                        }
                    }
                    else
                    {
                        ErrorMessage = $"API did not return a JSON array. Raw: {jsonData.Substring(0, Math.Min(300, jsonData.Length))}";
                    }
                }
                else
                {
                    ErrorMessage = "API returned empty response.";
                }

                AllSalesData = items ?? new List<SalesReportItem>();
                PopulateFilters(AllSalesData);
                BuildYearMonthSelectors();
                ApplyFilters();
                CurrentPage = 1;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading data: {ex.Message}";
            AllSalesData = new List<SalesReportItem>();
            FilteredSalesData = new List<SalesReportItem>();
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void BuildYearMonthSelectors()
    {
        AvailableYears = AllSalesData
            .Where(r => r.Year.HasValue)
            .Select(r => r.Year!.Value)
            .Distinct()
            .OrderByDescending(y => y)
            .ToList();

        if (AvailableYears.Count == 0)
        {
            AvailableYears.Add(DateTime.Now.Year);
        }

        if (!AvailableYears.Contains(SelectedYear))
        {
            SelectedYear = AvailableYears.First();
        }

        AvailableMonths = AllSalesData
            .Where(r => !string.IsNullOrEmpty(r.Month))
            .Select(r => r.Month!)
            .Distinct()
            .OrderBy(m =>
            {
                try
                {
                    return DateTime.ParseExact(m, "MMMM", System.Globalization.CultureInfo.InvariantCulture).Month;
                }
                catch
                {
                    return 13;
                }
            })
            .ToList();

        if (AvailableMonths.Count == 0)
        {
            AvailableMonths = new List<string>
            {
                "January", "February", "March", "April", "May", "June",
                "July", "August", "September", "October", "November", "December"
            };
        }

        if (string.IsNullOrEmpty(SelectedMonth) || !AvailableMonths.Contains(SelectedMonth))
        {
            SelectedMonth = DateTime.Now.ToString("MMMM");
        }
    }

    private IEnumerable<ColumnDefinition> GetVisibleColumns() =>
        GridColumns.Where(c => !VisibleColumns.ContainsKey(c.PropertyName) || VisibleColumns[c.PropertyName]);

    private void ToggleColumn(string columnKey)
    {
        var isVisible = VisibleColumns.TryGetValue(columnKey, out var visible) ? visible : true;
        // Prevent hiding the last visible column
        if (isVisible && GetVisibleColumns().Count() == 1)
        {
            return;
        }
        VisibleColumns[columnKey] = !isVisible;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleFilter()
    {
        ShowFilter = !ShowFilter;
    }

    private async Task RefreshData()
    {
        await LoadSalesDataAsync();
    }

    private void PrevPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

    private void NextPage()
    {
        var totalPages = CalculateTotalPages();
        if (CurrentPage < totalPages)
        {
            CurrentPage++;
        }
    }

    private int CalculateTotalPages()
    {
        var count = GetTabData().Count;
        return count == 0 ? 1 : (int)Math.Ceiling((double)count / RowsPerPage);
    }

    private void OnRowsPerPageChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            RowsPerPage = size;
            CurrentPage = 1;
        }
    }

