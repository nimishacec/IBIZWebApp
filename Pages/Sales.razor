@page "/sales"
@page "/sales/{InvId?}"
@using System.Text.Json.Serialization
@using IBIZWebApp.Models
@using IBIZWebApp.Services


@inject NavigationManager NavigationManager
@inject IBIZWebApp.Services.IReceiptVoucherService ReceiptVoucherService
@inject IBIZWebApp.Services.ISalesDropdownService SalesDropdownService
@inject HttpClient Http
@inject ICompanySelectionService CompanyService
@inject IBIZWebApp.Services.ITokenService TokenService
@inject IJSRuntime JS
@inject IBIZWebApp.Services.UserSessionService UserSession


<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
</head>
<PageTitle>Sales Entry</PageTitle>
<!-- Responsive mobile tweaks -->
<style>
    @@media (max-width: 600px) {
        .sales-entry-container, .order-entry-container, .sales-order-container {
            padding: 4vw 2vw 10vw 2vw !important;
            min-width: 0;
        }
        .info-grid, .header-grid, .header-grid-second {
            grid-template-columns: 1fr !important;
            gap: 10px !important;
        }
        .info-item, .header-item {
            min-width: 0 !important;
        }
        .btn, .btn-primary, .btn-secondary, .search-btn, .add-btn, .action-btn {
            font-size: 1rem !important;
            padding: 12px 0 !important;
        }
        .items-table, .data-table {
            font-size: 13px !important;
        }
        .modal-content {
            width: 98vw !important;
            min-width: 0 !important;
        }
        .modal-header h3 {
            font-size: 1.1rem !important;
        }
    }
</style>

<div class="sales-entry-container" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="true">
    <div style="margin-bottom: 16px;">
        <a href="/sales-list" class="btn btn-outline">&larr; Back to Sales List</a>
    </div>
    <!-- Header Title -->
    <div class="sales-header-title">
        <h2>Sales Entry</h2>
        <div class="header-date">
            <span>Date: @Sale.Date.ToString("dd-MMM-yyyy")</span>
        </div>
    </div>

    <!-- Customer & Main Info Section -->
    <div class="info-section">
        <div class="section-title">Customer Information</div>
        <div class="info-grid">
            <div class="info-item">
                <label>Customer Name (F10)</label>
                <input type="text" @bind="Sale.CustomerName" placeholder="Select Customer" class="info-input" disabled />
                <button class="lookup-btn" @onclick="OpenCustomerModal">F10</button>
            </div>
            <div class="info-item">
                <label>Mobile Number</label>
                <input type="text" @bind="Sale.MobileNumber" placeholder="Mobile" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>Address</label>
                <input type="text" @bind="Sale.Address" placeholder="Address" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>GSTIN</label>
                <input type="text" @bind="Sale.GSTIN" placeholder="GSTIN" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>Price List</label>
                <select @bind="Sale.PriceListID" @bind:after="OnPriceListChanged" class="info-input" @(IsViewMode ? "disabled" : null)>
                    @foreach (var pl in PriceLists)
                    {
                        <option value="@pl.Id">@pl.Name</option>
                    }
                </select>
            </div>
            <div class="info-item">
                <label>Cost Center</label>
                <select @bind="Sale.CostCenter" class="info-input" @(IsViewMode ? "disabled" : null)>
                    @foreach (var cc in CostCentres)
                    {
                        <option value="@cc.Name">@cc.Name</option>
                    }
                </select>
            </div>
            <div class="info-item">
                <label>Credit Days</label>
                <input type="number" @bind="Sale.CreditDays" placeholder="0" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>One Time Customer</label>
                <select @bind="Sale.OneTimeCustomer" class="info-input" @(IsViewMode ? "disabled" : null)>
                    <option>Regular Customer</option>
                    <option>One Time Customer</option>
                </select>
            </div>
            <div class="info-item">
                <label>Payment Mode</label>
                <select @bind="Sale.PaymentMode" class="info-input" @(IsViewMode ? "disabled" : null)>
                    <option>Cash</option>
                    <option>Credit</option>
                    <option>Cheque</option>
                    <option>Online</option>
                    
                </select>
            </div>
            <div class="info-item">
                <label>Points</label>
                <input type="number" @bind="Sale.Points" placeholder="0" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
        </div>
    </div>

    <!-- Additional Fields Section -->
    <div class="info-section">
        <div class="section-title">Additional Information</div>
        <div class="info-grid">
            <div class="info-item">
                <label>Date</label>
                <input type="date" @bind="Sale.Date" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>Invoice No</label>
                <input type="text" @bind="Sale.InvoiceNo" placeholder="Auto" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>Tax Mode</label>
                <select @bind="Sale.TaxMode" class="info-input" @(IsViewMode ? "disabled" : null)>
                    <option>GST</option>
                    <option>Non-GST</option>
                </select>
            </div>
            <div class="info-item">
                <label>Bill Type</label>
                <select @bind="Sale.BillType" class="info-input" @(IsViewMode ? "disabled" : null)>
                    <option>Regular Sales</option>
                    <option>Cash Sale</option>
                    <option>Credit Sale</option>
                </select>
            </div>
            <div class="info-item">
                <label>Sales Man</label>
                <select @bind="Sale.SalesMan" class="info-input" @(IsViewMode ? "disabled" : null)>
                    @foreach (var sm in Salesmen)
                    {
                        <option value="@sm.Name">@sm.Name</option>
                    }
                </select>
            </div>
            <div class="info-item">
                <label>Agent</label>
                <select @bind="Sale.AgentID" @bind:after="OnAgentChanged" class="info-input" @(IsViewMode ? "disabled" : null)>
                    @foreach (var ag in Agents)
                    {
                        <option value="@ag.Id">@ag.Name</option>
                    }
                </select>
            </div>
            <div class="info-item">
                <label>E-Invoice IRN</label>
                <input type="text" @bind="Sale.EInvoiceIRN" placeholder="IRN" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <div class="info-item">
                <label>Customer Balance</label>
                <input type="number" @bind="Sale.CustomerBalance" placeholder="0" class="info-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
        </div>
    </div>

    <!-- Item Search Section -->
    <div class="item-search-section">
        <div class="search-controls">
            <div class="search-group">
                <label>Item Search Mode (Ctrl +</label>
                <input type="text" @bind="ItemSearchQuery" @oninput="FilterItems" placeholder="Search by Item Code or Name" class="search-input" @(IsViewMode ? "readonly disabled" : null) />
            </div>
            <button class="search-btn" @onclick="OpenItemSearch" disabled="@(IsViewMode)">Search Item</button>
            <button class="add-btn" @onclick="OpenItemModal" disabled="@(IsViewMode)">Add Item</button>
        </div>
    </div>

    <!-- Items Table Section -->
    <div class="items-section">
        <div class="section-title">Items</div>
        <div class="items-table-wrapper">
            <table class="items-table">
                <thead>
                    <tr>
                        <th>SNo</th>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>BatchCode</th>
                        <th>Expiry</th>
                        <th>Item Narration</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>MRP</th>
                        <th>Gross Amt</th>
                        <th>Tax %</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Sale.Items != null && Sale.Items.Count > 0)
                    {
                        @foreach (var (item, index) in Sale.Items.Select((x, i) => (x, i + 1)))
                        {
                            <tr>
                                <td>@index</td>
                                <td>@item.ItemCode</td>
                                <td>@item.ItemName</td>
                                <td>@item.BatchCode</td>
                                <td>@item.Expiry</td>
                                <td>@item.ItemNarration</td>
                                <td>
                                    @if (IsViewMode)
                                    {
                                        @item.Qty
                                    }
                                    else
                                    {
                                        <input type="number" @bind="item.Qty" class="qty-input" />
                                    }
                                </td>
                                <td>@item.Rate.ToString("F2")</td>
                                <td>@item.MRP.ToString("F2")</td>
                                <td>@((item.Qty * item.Rate).ToString("F2"))</td>
                                <td>@item.TaxPer.ToString("F1")</td>
                                <td>
                                    @if (!IsViewMode)
                                    {
                                        <button class="delete-btn" @onclick="() => RemoveItem(index - 1)">Delete</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="12" style="text-align: center; padding: 20px; color: #999;">No items added yet</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Summary Section -->
    <div class="summary-section">
        <div class="summary-left">
            <div class="summary-item">
                <label>Narration</label>
                <textarea @bind="Sale.Narration" placeholder="Add narration" class="narration-input"></textarea>
            </div>
        </div>
        <div class="summary-right">
            <div class="summary-grid">
                <div class="summary-row">
                    <span class="summary-label">Total Qty:</span>
                    <span class="summary-value">@TotalQty</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Gross Amount:</span>
                    <span class="summary-value large">@GrossAmount.ToString("F2")</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Tax Amount:</span>
                    <span class="summary-value">@TaxAmount.ToString("F2")</span>
                </div>
                <div class="summary-row highlight">
                    <span class="summary-label">Net Amount:</span>
                    <span class="summary-value large">@NetAmount.ToString("F2")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    @if (!IsViewMode)
    {
        <div class="action-buttons">
            <button class="btn btn-primary" @onclick="SaveSale">Save</button>
            <button class="btn btn-secondary" @onclick="PrintSale">Print</button>
            <button class="btn btn-danger" @onclick="CancelSale">Cancel</button>
        </div>
    }

    <!-- Customer Modal -->
    @if (ShowCustomerModal)
    {
        <div class="modal-overlay" @onclick="() => ShowCustomerModal = false">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Select Customer</h3>
                    <button class="close-btn" @onclick="() => ShowCustomerModal = false">&times;</button>
                </div>
                <div class="modal-body">
                    <input type="text" @bind="CustomerSearch" @oninput="FilterCustomers" placeholder="Search customer..." class="modal-search" />
                    <div class="modal-list">
                        @foreach (var customer in FilteredCustomers)
                        {
                            <div class="modal-item" @onclick="() => SelectCustomer(customer)">
                                <div class="item-name">@customer.Name</div>
                                <div class="item-detail">@customer.Phone</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Item Modal -->
    @if (ShowItemModal)
    {
        <div class="modal-overlay" @onclick="() => ShowItemModal = false">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Add Item</h3>
                    <button class="close-btn" @onclick="() => ShowItemModal = false">&times;</button>
                </div>
                <div class="modal-body">
                    <input type="text" @bind="ItemSearchQuery" @oninput="FilterItems" placeholder="Search item..." class="modal-search" />
                    <div class="modal-list">
                        @foreach (var item in FilteredItems)
                        {
                            <div class="modal-item" @onclick="async () => await AddItemAsync(item)">
                                <div class="item-name">@item.ItemName</div>
                                <div class="item-detail">@item.ItemCode - @item.Rate.ToString("F2")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? InvId { get; set; }
    private bool IsEdit => !string.IsNullOrEmpty(InvId) && InvId != "0";
    private bool IsViewMode => NavigationManager.Uri.Contains("view=true");
    private SaleRecord Sale = new SaleRecord();
    private List<SalesItem> AllItems = new();
    private List<SalesItem> FilteredItems = new();
    private List<CustomerRecord> AllCustomers = new();
    private List<CustomerRecord> FilteredCustomers = new();
    private string ItemSearchQuery = "";
    private string CustomerSearch = "";
    private bool ShowItemModal = false;
    private bool ShowCustomerModal = false;
    // Removed duplicate InvId and IsEdit definitions
    protected override async Task OnInitializedAsync()
    {
        await InitializeData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsEdit || IsViewMode)
        {
            await LoadSaleForEdit();
            SyncDropdownSelections();
        }
    }

    private async Task LoadSaleForEdit()
    {
        try
        {
            var cdkey = CompanyService.SelectedCompany?.LicenceKey ?? string.Empty;
            var companyCode = CompanyService.SelectedCompany?.CompanyCode ?? string.Empty;
            var url = $"{ApiConstants.BaseUrl}/api/Order/sales/{InvId}";
            var request = new HttpRequestMessage(HttpMethod.Get, url);
            request.Headers.Add("CdyKey", cdkey);
            request.Headers.Add("CompanyCode", companyCode);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var sale = System.Text.Json.JsonSerializer.Deserialize<SaleRecord>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (sale != null)
                {
                    Sale = sale;
                }
            }
        }
        catch { }
    }

    private async Task InitializeData()
    {
        await LoadCustomersAsync();

        // Load dropdowns from API
        PriceLists = await SalesDropdownService.GetPriceListsAsync();
        CostCentres = await SalesDropdownService.GetCostCentresAsync();
        Salesmen = await SalesDropdownService.GetSalesmenAsync();
        Agents = await SalesDropdownService.GetAgentsAsync();
        SyncDropdownSelections();

        await FetchNewInvIdAsync("SALES","Sales");

        FilteredItems = AllItems;
        FilteredCustomers = AllCustomers;
        Sale.Date = DateTime.Now;
        StateHasChanged();
    }

    private async Task LoadCustomersAsync()
    {
        var apiCustomers = await SalesDropdownService.GetCustomersAsync("");
        AllCustomers = apiCustomers.Select(c => new CustomerRecord
        {
            Name = c.Name,
            Phone = c.Mobile,
            Address = c.Address,
            GSTIN = c.GSTIN,
            LedgerId = (int)c.LID,
            Balance = c.Balance
        }).ToList();
        FilteredCustomers = AllCustomers;
    }

    private async Task OpenCustomerModal()
    {
        await LoadCustomersAsync();
        CustomerSearch = string.Empty;
        ShowCustomerModal = true;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "F10")
        {
            await OpenCustomerModal();
        }
    }

    private void SyncDropdownSelections()
    {
        if (PriceLists.Count > 0)
        {
            if (Sale.PriceListID == 0 && !string.IsNullOrWhiteSpace(Sale.PriceList))
            {
                var mapped = PriceLists.FirstOrDefault(p => string.Equals(p.Name?.Trim(), Sale.PriceList.Trim(), StringComparison.OrdinalIgnoreCase));
                if (mapped != null)
                {
                    Sale.PriceListID = mapped.Id;
                }
            }

            if (Sale.PriceListID == 0)
            {
                Sale.PriceListID = PriceLists[0].Id;
            }

            var selectedPriceList = PriceLists.FirstOrDefault(p => p.Id == Sale.PriceListID);
            if (selectedPriceList != null)
            {
                Sale.PriceList = selectedPriceList.Name;
            }
        }

        if (Agents.Count > 0)
        {
            if (Sale.AgentID == 0 && !string.IsNullOrWhiteSpace(Sale.Agent))
            {
                var mapped = Agents.FirstOrDefault(a => string.Equals(a.Name?.Trim(), Sale.Agent.Trim(), StringComparison.OrdinalIgnoreCase));
                if (mapped != null)
                {
                    Sale.AgentID = mapped.Id;
                }
            }

            if (Sale.AgentID == 0)
            {
                Sale.AgentID = Agents[0].Id;
            }

            var selectedAgent = Agents.FirstOrDefault(a => a.Id == Sale.AgentID);
            if (selectedAgent != null)
            {
                Sale.Agent = selectedAgent.Name;
            }
        }
    }

    private void OnPriceListChanged()
    {
        var selected = PriceLists.FirstOrDefault(p => p.Id == Sale.PriceListID);
        if (selected != null)
        {
            Sale.PriceList = selected.Name;
        }
    }

    private void OnAgentChanged()
    {
        var selected = Agents.FirstOrDefault(a => a.Id == Sale.AgentID);
        if (selected != null)
        {
            Sale.Agent = selected.Name;
        }
    }

    private async Task FetchNewInvIdAsync(string SALES, string Sales)
    {
        try
        {
            // Get company details from selected company
            var cdkey = CompanyService.SelectedCompany?.LicenceKey ?? string.Empty;
            var companyCode = CompanyService.SelectedCompany?.CompanyCode ?? string.Empty;
            var url = $"http://localhost:5090/api/Order/last-invid?vchrType={Uri.EscapeDataString(SALES)}&nodeName={Uri.EscapeDataString(Sales)}";
            var request = new HttpRequestMessage(HttpMethod.Get, url);
            request.Headers.Add("CdyKey", cdkey);
            request.Headers.Add("CompanyCode", companyCode);

            // Add Bearer token to Authorization header
            var token = await TokenService.GetTokenAsync();
            if (!string.IsNullOrWhiteSpace(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var lastInvIdResponse = await Http.SendAsync(request);
            if (lastInvIdResponse.IsSuccessStatusCode)
            {
                var lastInvIdString = await lastInvIdResponse.Content.ReadAsStringAsync();
                if (double.TryParse(lastInvIdString, out var lastInvId))
                {
                    newInvId = lastInvId + 1;
                }
                else
                {
                    newInvId = 1;
                }
            }
            else
            {
                newInvId = 1;
            }
        }
        catch
        {
            newInvId = 1;
        }
    }

    private async Task OpenItemModal()
    {
        ShowItemModal = true;
        ItemSearchQuery = "";
        try
        {
            var cdkey = CompanyService.SelectedCompany?.LicenceKey ?? string.Empty;
            var companyCode = CompanyService.SelectedCompany?.CompanyCode ?? string.Empty;
            var request = new HttpRequestMessage(HttpMethod.Get, $"{ApiConstants.BaseUrl}/api/Order/items");
            request.Headers.Add("CdyKey", cdkey);
            request.Headers.Add("CompanyCode", companyCode);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var items = System.Text.Json.JsonSerializer.Deserialize<List<SalesItem>>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                AllItems = items ?? new List<SalesItem>();
                foreach (var item in AllItems)                {
                    if (item.Rate == 0.00m)
                    {
                        item.Rate = item.MRP;
                    }
                }
                FilteredItems = AllItems;
            }
            else
            {
                AllItems = new List<SalesItem>();
                FilteredItems = AllItems;
            }
        }
        catch
        {
            AllItems = new List<SalesItem>();
            FilteredItems = AllItems;
        }
    }

    private async Task AddItemAsync(SalesItem item)
    {
        string batchUnique = string.Empty;
        try
        {
            var url = $"{ApiConstants.BaseUrl}/api/Order/GetBatchByItemId/{item.ItemId}";
            var request = new HttpRequestMessage(HttpMethod.Get, url);
            var cdkey = CompanyService.SelectedCompany?.LicenceKey ?? string.Empty;
            var companyCode = CompanyService.SelectedCompany?.CompanyCode ?? string.Empty;
            request.Headers.Add("CdyKey", cdkey);
            request.Headers.Add("CompanyCode", companyCode);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var batchOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var trimmedJson = json?.Trim() ?? string.Empty;
                BatchUniqueModel? first = null;
                if (trimmedJson.StartsWith("["))
                {
                    var list = System.Text.Json.JsonSerializer.Deserialize<List<BatchUniqueModel>>(trimmedJson, batchOptions);
                    first = list?.FirstOrDefault();
                }
                else if (trimmedJson.StartsWith("{"))
                {
                    first = System.Text.Json.JsonSerializer.Deserialize<BatchUniqueModel>(trimmedJson, batchOptions);
                }
                batchUnique = first?.BatchUnique ?? first?.BatchCode ?? string.Empty;
            }
        }
        catch { }
        Sale.Items.Add(new SaleItem
        {
            ItemId = item.ItemId,
            ItemCode = item.ItemCode,
            ItemName = item.ItemName,
            Rate = item.MRP,
            MRP = item.MRP,
            TaxPer = item.TaxPercent,
            Qty = 1,
            BatchUnique = batchUnique
        });
        ShowItemModal = false;
        CalculateTotals();
    }

    private void FilterItems(ChangeEventArgs e)
    {
        ItemSearchQuery = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(ItemSearchQuery))
        {
            FilteredItems = AllItems;
        }
        else
        {
            FilteredItems = AllItems
                .Where(x => x.ItemCode.Contains(ItemSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                           x.ItemName.Contains(ItemSearchQuery, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void FilterCustomers(ChangeEventArgs e)
    {
        CustomerSearch = e.Value?.ToString() ?? "";
        FilteredCustomers = AllCustomers
            .Where(x => x != null &&
                ((x.Name != null && x.Name.Contains(CustomerSearch.Trim(), StringComparison.OrdinalIgnoreCase)) ||
                 (x.Phone != null && x.Phone.Contains(CustomerSearch.Trim(), StringComparison.OrdinalIgnoreCase))))
            .ToList();
    }


    private async void SelectCustomer(CustomerRecord customer)
    {
        Sale.CustomerName = customer.Name;
        Sale.MobileNumber = customer.Phone;
        ShowCustomerModal = false;

        // Example: Assume customer.Name is unique and maps to a ledger
        // In real app, you should have a LedgerId property in CustomerRecord
        var ledgers = await ReceiptVoucherService.GetCustomerLedgersAsync();
        var ledger = ledgers.FirstOrDefault(l => l.LedgerName == customer.Name);
        if (ledger != null)
        {
            var balance = await ReceiptVoucherService.GetLedgerBalanceAsync(ledger.LedgerId);
            Sale.CustomerBalance = balance;
        }
        else
        {
            Sale.CustomerBalance = 0;
        }
        StateHasChanged();
    }

    private async void AddItem(SalesItem item)
    {
        Sale.Items.Add(new SaleItem
        {
            ItemId = item.ItemId,
            ItemCode = item.ItemCode,
            ItemName = item.ItemName,
            Rate = item.MRP,
            MRP = item.MRP,
            TaxPer = item.TaxPercent,
            Qty = 1,
            BatchUnique = item.BatchUnique
        });
        ShowItemModal = false;
        CalculateTotals();
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < Sale.Items.Count)
        {
            Sale.Items.RemoveAt(index);
            CalculateTotals();
        }
    }

    private void CalculateTotals()
    {
        // Recalculate totals when items change
        StateHasChanged();
    }

    private async Task OpenItemSearch()
    {
        await OpenItemModal();
    }

    private int TotalQty => Sale.Items.Sum(x => x.Qty);
    private decimal GrossAmount => Sale.Items.Sum(x => x.Qty * x.Rate);
    private decimal TaxAmount => Sale.Items.Sum(x => (x.Qty * x.Rate * x.TaxPer) / 100);
    private decimal NetAmount => GrossAmount + TaxAmount;
 private double newInvId = 0;

